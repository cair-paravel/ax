{
	# For local dev you may hit rate limits if you keep restarting.
	# Uncomment to use Let's Encrypt staging:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	admin 0.0.0.0:2019
}

{$PLATFORM_BASE_DOMAIN} {
	handle /_ax/health {
		respond "ok" 200
	}

	# Proxy the runner API behind the platform domain so we don't need to expose :8080.
	# Example: https://sixty.to/_ax/runner/health -> runner /health
	handle_path /_ax/runner/* {
		reverse_proxy agentx-runner:8080
	}
}

import /etc/caddy/apps/*.caddy


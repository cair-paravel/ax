{
	# For local dev you may hit rate limits if you keep restarting.
	# Uncomment to use Let's Encrypt staging:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	admin 0.0.0.0:2019
}

# Runner API on HTTPS when DNS has runner.<hostname> (see caddy-runner-subdomain.caddy; omitted for IP-only bases).
import /etc/caddy/caddy-runner-subdomain.caddy

# Runner API on HTTP apex: required when PLATFORM_BASE_DOMAIN is an IPv4 address (no runner.<ip> in DNS/TLS).
# For hostnames, prefer https://runner.<domain>; this still works as a fallback on :80.
http://{$PLATFORM_BASE_DOMAIN} {
	handle /v1/* {
		reverse_proxy ax-runner:8080
	}
	handle /health {
		reverse_proxy ax-runner:8080
	}
}

{$PLATFORM_BASE_DOMAIN} {
	handle /_ax/health {
		respond "ok" 200
	}

	# Platform-path apps: runner generates route snippets here.
	import /etc/caddy/apps/platform-routes/*.caddy
}

# Custom-domain / platform-subdomain apps are generated here.
import /etc/caddy/apps/app-*.caddy

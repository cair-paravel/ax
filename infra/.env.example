# Copy to .env or run ./setup.sh from the repo root
# Your hostname or public IP (no https://). Same host serves runner (/v1, /health) and path apps. For a name, point DNS A/AAAA here.
PLATFORM_BASE_DOMAIN=localhost

# Shared secret for ax login / runner API (use a long random string in production).
RUNNER_TOKEN=local-dev-token
